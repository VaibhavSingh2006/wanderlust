<% layout("layouts/boilerplate") %>

<div class="success-wrapper">

  <div class="success-card">

    <div class="checkmark">✔</div>

    <h2>Booking Confirmed</h2>

    <p>Your stay has been successfully booked.</p>

    <p class="redirect-text">
      Redirecting to your bookings in <span id="countdown">4</span>s
    </p>

    <a href="/profile" class="btn-view">View My Bookings</a>

  </div>

</div>

<style>

/* Background glow */

.success-wrapper{
  min-height:75vh;
  display:flex;
  justify-content:center;
  align-items:center;
  padding:20px;

  background: radial-gradient(circle at top,
  rgba(255,56,92,0.18),
  transparent 60%);
}


/* Glass card */

.success-card{
  backdrop-filter: blur(18px);
  background: rgba(255,255,255,0.75);
  border:1px solid rgba(255,255,255,0.4);

  padding:40px 35px;
  border-radius:18px;

  text-align:center;

  box-shadow:0 20px 40px rgba(0,0,0,0.12);

  max-width:420px;
  width:100%;

  animation: cardPop .5s ease;
}


/* Checkmark */

.checkmark{
  width:80px;
  height:80px;

  background:#ff385c;
  color:white;

  display:flex;
  align-items:center;
  justify-content:center;

  font-size:36px;
  border-radius:50%;

  margin:0 auto 15px;

  box-shadow:0 10px 25px rgba(255,56,92,0.45);

  animation: checkPop .45s ease;
}


/* Title */

.success-card h2{
  font-weight:600;
  margin-bottom:8px;
}


/* Text */

.success-card p{
  color:#555;
}


/* Button */

.btn-view{
  display:inline-block;

  margin-top:20px;
  padding:12px 28px;

  background:#ff385c;
  color:white;

  border-radius:10px;
  text-decoration:none;

  font-weight:600;

  transition:.2s;
}

.btn-view:hover{
  background:#e61e4d;
  transform:translateY(-2px);
}


/* Animations */

@keyframes cardPop{
  0%{
    opacity:0;
    transform:scale(.92);
  }
  100%{
    opacity:1;
    transform:scale(1);
  }
}

@keyframes checkPop{
  0%{
    transform:scale(.4);
    opacity:0;
  }
  60%{
    transform:scale(1.1);
  }
  100%{
    transform:scale(1);
  }
}


/* Mobile */

@media (max-width:600px){

  .success-card{
    padding:30px 24px;
  }

  .success-card h2{
    font-size:22px;
  }

}

</style>


<script>

let time = 4;

const countdown = document.getElementById("countdown");

const timer = setInterval(()=>{

  time--;
  countdown.innerText = time;

  if(time<=0){
    clearInterval(timer);
    window.location.href="/profile";
  }

},1000);

</script>